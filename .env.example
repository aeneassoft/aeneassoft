# ── Auth ──────────────────────────────────────────────────────────────────────
API_KEY=your-api-key                           # Single-tenant fallback (or use multi-tenant via /api/keys)
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://aeneassoft.com,https://www.aeneassoft.com

# ── Proxy ─────────────────────────────────────────────────────────────────────
UPSTREAM_OPENAI_URL=https://api.openai.com
UPSTREAM_ANTHROPIC_URL=https://api.anthropic.com
UPSTREAM_TIMEOUT_MS=30000                        # Upstream request timeout (default: 30s)
KAFKA_BROKERS=localhost:9092
KAFKA_BATCH_SIZE=50                              # Spans per Kafka batch (default: 50)
KAFKA_FLUSH_MS=500                               # Kafka flush interval (default: 500ms)
ZERO_DATA_RETENTION=false
DATA_RETENTION_DAYS=30

# ── Backend ───────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=aeneassoft
PORT=3001

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@aeneassoft.com

# ── Optional ──────────────────────────────────────────────────────────────────
# MODEL_PRICING={"custom-model":{"prompt":1,"completion":2}}
# SIGNING_PRIVATE_KEY=...
# SIGNING_PUBLIC_KEY=...
